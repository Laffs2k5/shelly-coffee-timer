# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env
#
# Then load it before running any script:
#
#   source .env
#
# IMPORTANT: .env is gitignored — never rename it to something
# that is NOT covered by the .gitignore patterns (*.env, secrets.*).
# This repo is PUBLIC. Do not commit real credentials anywhere.

AIO_USER="your_adafruit_io_username"
AIO_KEY="your_adafruit_io_key"
SHELLY_IP="192.168.1.xxx"
